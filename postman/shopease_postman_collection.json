{
  "info": {
    "_postman_id": "d95b7a59-4c22-4c9c-9a9b-6cf60be0ab10",
    "name": "Ease Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for Ease Backend (Laravel). Uses variables: {{baseUrl}}, {{token}}."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Sales (v1)",
      "item": [
        {
          "name": "Import sales CSV",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sales/import",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sales", "import"]
            },
            "description": "Uploads a CSV file (field name: file). Validated as csv/txt, max 50MB."
          }
        },
        {
          "name": "List sales",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sales/sales?branch=&from=&to=&category=&payment_method=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sales", "sales"],
              "query": [
                { "key": "branch", "value": "", "description": "Optional" },
                { "key": "from", "value": "", "description": "Optional (date/string)" },
                { "key": "to", "value": "", "description": "Optional (date/string)" },
                { "key": "category", "value": "", "description": "Optional" },
                { "key": "payment_method", "value": "", "description": "Optional" }
              ]
            }
          }
        },
        {
          "name": "Sales summary",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sales/sales/summary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sales", "sales", "summary"]
            }
          }
        },
        {
          "name": "Export sales CSV",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "text/csv" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sales/export/csv?branch=&from=&to=&category=&payment_method=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sales", "export", "csv"],
              "query": [
                { "key": "branch", "value": "", "description": "Optional" },
                { "key": "from", "value": "", "description": "Optional (date/string)" },
                { "key": "to", "value": "", "description": "Optional (date/string)" },
                { "key": "category", "value": "", "description": "Optional" },
                { "key": "payment_method", "value": "", "description": "Optional" }
              ]
            },
            "description": "Streams a CSV export when <= 10k rows; otherwise returns a JSON processing response."
          }
        },
        {
          "name": "Export sales Excel",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sales/export/excel?branch=&from=&to=&category=&payment_method=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sales", "export", "excel"],
              "query": [
                { "key": "branch", "value": "", "description": "Optional" },
                { "key": "from", "value": "", "description": "Optional (date/string)" },
                { "key": "to", "value": "", "description": "Optional (date/string)" },
                { "key": "category", "value": "", "description": "Optional" },
                { "key": "payment_method", "value": "", "description": "Optional" }
              ]
            },
            "description": "Downloads an Excel report when <= 10k rows; otherwise returns a JSON processing response."
          }
        }
      ]
    }
  ]
}
